# Copy this to .env.local and fill in your values

# ── Upstash Redis ──────────────────────────────────────────────
# 1. Go to vercel.com → your project → Integrations
# 2. Search "Upstash Redis" in the Marketplace and add it (free tier)
# 3. Vercel auto-populates these two vars in your project env
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ── OpenWeatherMap ─────────────────────────────────────────────
# Free tier — 1,000 calls/day. Sign up at openweathermap.org/api
# Same key goes in both vars (one server-side, one client-side)
OPENWEATHER_API_KEY=your_openweather_key_here
NEXT_PUBLIC_OPENWEATHER_KEY=your_openweather_key_here

# ── Cron secret ────────────────────────────────────────────────
# Make up any random string, e.g: openssl rand -hex 16
# Paste the same value in Vercel dashboard → Settings → Env Vars
CRON_SECRET=your_random_secret_here
